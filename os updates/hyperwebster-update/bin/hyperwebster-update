#!/usr/bin/env bash
# hyperwebster-update — update a HyperWebster system. Modeled on Omarchy's update flow.
# Fetches the latest layer from GitHub, upgrades packages, then runs forward-only
# migrations against ~/.local/share/hyperwebster/.
set -euo pipefail

# --- resolve the HyperWebster source root (works through the ~/.local/bin symlink) --
resolve_paths() {
  SELF=$(readlink -f -- "${1:-$0}")
  BIN_DIR=$(dirname -- "$SELF")
  UPDATE_DIR=$(dirname -- "$BIN_DIR")              # .../hyperwebster-update
  ROOT=$(dirname -- "$UPDATE_DIR")                 # .../hyperwebster (layer root)
  MIG_DIR="$UPDATE_DIR/migrations"
}
resolve_paths "$0"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/hyperwebster"
STATE="$STATE_DIR/applied"
VERSION_FILE="$STATE_DIR/layer-version"
PULL_SCRIPT="$BIN_DIR/pull-layer.sh"

# --- options ------------------------------------------------------------------
ASSUME_YES=0; DO_PACKAGES=1; DO_SNAPSHOT=1; DO_CAELESTIA=0; DO_PULL=1; FORCE_MIGRATIONS=0
for a in "$@"; do
  case "$a" in
    -y|--yes)       ASSUME_YES=1 ;;
    --no-packages)  DO_PACKAGES=0 ;;
    --no-snapshot)  DO_SNAPSHOT=0 ;;
    --no-pull)      DO_PULL=0 ;;
    --pull-only)    DO_PACKAGES=0; DO_SNAPSHOT=0; DO_PULL=1 ;;
    --force-migrations|--reapply-all) FORCE_MIGRATIONS=1 ;;
    --caelestia)    DO_CAELESTIA=1 ;;
    -h|--help)
      cat <<EOF
Usage: hyperwebster-update [options]
  -y, --yes         non-interactive (pass --noconfirm to the package upgrade)
  --no-packages     skip the pacman/AUR upgrade (layer refresh + migrations only)
  --no-snapshot     skip the pre-update snapper snapshot
  --no-pull         skip fetching the latest layer from GitHub (offline / ISO snapshot)
  --pull-only       refresh layer + migrations only (same as --no-packages --no-snapshot)
  --force-migrations, --reapply-all
                    re-run every migration (ISO installs that marked all applied
                    without running installers — use after a manual layer pull)
  --caelestia       also 'git pull' the Caelestia dotfiles (may clobber local edits)

By default hyperwebster-update pulls the latest HyperWebster layer from GitHub
(main branch) into ~/.local/share/hyperwebster/, then runs any new migrations.
Override the URL with HYPERWEBSTER_LAYER_URL or ~/.config/hyperwebster/layer-source.conf.
EOF
      exit 0 ;;
    *) echo "unknown option: $a" >&2; exit 2 ;;
  esac
done

log() { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }

show_layer_version() {
  if [ -f "$VERSION_FILE" ]; then
    local when commit mig
    when=$(sed -n 's/^fetched_at=//p' "$VERSION_FILE" | head -1)
    commit=$(sed -n 's/^commit=//p' "$VERSION_FILE" | head -1)
    mig=$(sed -n 's/^migrations=//p' "$VERSION_FILE" | head -1)
    if [ -n "${commit:-}" ]; then
      log "layer version: ${commit:0:7} (${when:-unknown time}, ${mig:-?} migrations)"
    else
      log "layer version: fetched ${when:-unknown} (${mig:-?} migrations)"
    fi
  else
    warn "layer version: ISO install snapshot (no GitHub pull recorded yet)"
  fi
}

# --- 1. snapshot (btrfs/snapper, best effort) ---------------------------------
snapshot() {
  command -v snapper >/dev/null 2>&1 || { log "snapper not present — skipping snapshot"; return; }
  local cfg
  cfg=$(snapper list-configs 2>/dev/null | awk 'NR>2 {print $1; exit}')
  [ -n "${cfg:-}" ] || { log "no snapper config — skipping snapshot"; return; }
  log "pre-update snapshot (config: $cfg)"
  sudo snapper -c "$cfg" create -d "hyperwebster-update $(date '+%Y-%m-%d %H:%M')" || warn "snapshot failed (continuing)"
}

# --- 2. ensure an AUR helper (bootstrap yay if missing) -----------------------
HELPER=""
ensure_helper() {
  local h
  for h in yay paru; do command -v "$h" >/dev/null 2>&1 && { HELPER="$h"; return; }; done
  log "no AUR helper found — bootstrapping yay (yay-bin)"
  sudo pacman -S --needed --noconfirm git base-devel
  local tmp; tmp=$(mktemp -d)
  git clone --depth 1 https://aur.archlinux.org/yay-bin.git "$tmp/yay-bin"
  ( cd "$tmp/yay-bin" && makepkg -si --noconfirm )
  rm -rf "$tmp"
  HELPER=yay
}

# --- 3. package upgrade (repo + AUR) ------------------------------------------
update_packages() {
  ensure_helper
  local nc=""; [ "$ASSUME_YES" = 1 ] && nc="--noconfirm"
  local menus=""
  [ "$HELPER" = yay ] && menus="--answerupgrade None --answerclean None --answerdiff None --answeredit None"
  log "upgrading packages with $HELPER"
  "$HELPER" -Syu $menus $nc
}

# --- 4. layer pull (GitHub) ---------------------------------------------------
pull_layer() {
  if [ ! -x "$PULL_SCRIPT" ]; then
    warn "pull-layer.sh missing — skipping layer fetch (run from a refreshed ISO or manual pull)"
    return 1
  fi
  HYPERWEBSTER_LAYER="$ROOT" bash "$PULL_SCRIPT"
  # pull-layer may refresh this script; re-resolve all paths after sync.
  resolve_paths "$SELF"
}

# --- 5. migrations (re-apply / advance the HyperWebster layer) ----------------
run_migrations() {
  mkdir -p "$STATE_DIR"; touch "$STATE"
  local m base applied=0 skipped=0 failed=0
  shopt -s nullglob
  local files=("$MIG_DIR"/*.sh)
  shopt -u nullglob
  # Defensive: older pull_layer() bug doubled hyperwebster-update in MIG_DIR.
  if [ ${#files[@]} -eq 0 ]; then
    local alt="$UPDATE_DIR/migrations"
    if [ "$alt" != "$MIG_DIR" ] && [ -d "$alt" ]; then
      shopt -s nullglob
      files=("$alt"/*.sh)
      shopt -u nullglob
      if [ ${#files[@]} -gt 0 ]; then
        warn "corrected migrations path -> $alt"
        MIG_DIR="$alt"
      fi
    fi
  fi
  if [ ${#files[@]} -eq 0 ]; then
    warn "no migrations found under $MIG_DIR"
    return 0
  fi
  [ "$FORCE_MIGRATIONS" = 1 ] && log "re-running all migrations (--force-migrations)"
  for m in "${files[@]}"; do
    base=$(basename "$m")
    if [ "$FORCE_MIGRATIONS" != 1 ] && grep -qxF "$base" "$STATE" 2>/dev/null; then
      skipped=$((skipped + 1))
      continue
    fi
    log "migration: $base"
    if HYPERWEBSTER_SRC="$ROOT" HYPERWEBSTER_LAYER="$ROOT" bash "$m"; then
      grep -qxF "$base" "$STATE" 2>/dev/null || echo "$base" >> "$STATE"
      applied=$((applied + 1))
    else
      failed=$((failed + 1))
      warn "migration $base FAILED (exit $?)"
      exit 1
    fi
  done
  if [ "$FORCE_MIGRATIONS" = 1 ] && [ "$applied" -gt 0 ]; then
    log "$applied migration(s) re-applied"
    log "restart the desktop shell: Ctrl+Super+Alt+R (or log out/in)"
  elif [ "$applied" -gt 0 ]; then
    log "$applied new migration(s) applied, $skipped already applied"
    log "restart the desktop shell: Ctrl+Super+Alt+R (or log out/in)"
  elif [ "$skipped" -gt 0 ]; then
    log "0 new migrations ($skipped already applied)"
  else
    log "0 migrations in tree"
  fi
}

# --- 6. caelestia dotfiles (opt-in) -------------------------------------------
update_caelestia() {
  local d="$HOME/.local/share/caelestia"
  [ -d "$d/.git" ] || { log "caelestia repo not found — skipping"; return; }
  log "git pull caelestia (ff-only)"
  git -C "$d" pull --ff-only || warn "caelestia pull skipped (local changes / non-ff)"
}

# --- run ----------------------------------------------------------------------
if [ "$ASSUME_YES" != 1 ]; then
  printf 'Update HyperWebster now? [y/N] '; read -r ans
  case "${ans:-}" in y|Y) ;; *) echo "aborted"; exit 0 ;; esac
fi

show_layer_version
[ "$DO_SNAPSHOT" = 1 ] && snapshot
if [ "$DO_PULL" = 1 ]; then
  pull_layer || true
  show_layer_version
fi
[ "$DO_PACKAGES" = 1 ] && update_packages
run_migrations
[ "$DO_CAELESTIA" = 1 ] && update_caelestia
command -v hyperwebster-reboot-check >/dev/null 2>&1 && hyperwebster-reboot-check || true
log "HyperWebster up to date"
