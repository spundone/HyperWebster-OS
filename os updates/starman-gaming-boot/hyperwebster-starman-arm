#!/bin/bash
# hyperwebster-starman-arm — arm one-shot SDDM autologin into the DeckShift
# gaming session when the kernel cmdline contains hyperwebster.starman=1.
# Invoked by hyperwebster-starman-boot.service before SDDM starts.
set -euo pipefail

grep -q 'hyperwebster\.starman=1' /proc/cmdline || exit 0

CONF="/etc/sddm.conf.d/zz-gaming-session.conf"
MARKER="/run/deckshift-session-switch"

# DeckShift, Deckify/Chimera, or any compatible gamescope session.
if SESSION=$(/usr/local/bin/hyperwebster-gaming-session 2>/dev/null); then
  :
elif compgen -G "/usr/share/wayland-sessions/gamescope-session-steam-nm.desktop" >/dev/null \
     || compgen -G "/usr/share/wayland-sessions/gamescope-session-steam.desktop" >/dev/null; then
  for s in gamescope-session-steam-nm gamescope-session-steam gamescope-session-steam-plus; do
    if compgen -G "/usr/share/wayland-sessions/${s}.desktop" >/dev/null \
       || compgen -G "/usr/share/xsessions/${s}.desktop" >/dev/null; then
      SESSION="$s"
      break
    fi
  done
else
  echo "hyperwebster-starman: no gamescope gaming session installed — skipping" >&2
  exit 0
fi

USER_NAME=""
for u in $(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 { print $1 }'); do
  getent group wheel | grep -qw "$u" && USER_NAME="$u" && break
done
USER_NAME="${USER_NAME:-$(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 { print $1; exit }')}"
[[ -n "$USER_NAME" ]] || { echo "hyperwebster-starman: no desktop user found" >&2; exit 1; }

cat > "$CONF" << EOF
[Autologin]
User=${USER_NAME}
Session=${SESSION}
Relogin=false
EOF
touch "$MARKER"
echo "hyperwebster-starman: armed one-shot autologin for $USER_NAME -> $SESSION"
