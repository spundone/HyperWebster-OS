#!/bin/bash
# hyperwebster-luks-tpm-status — diagnose LUKS TPM auto-unlock and Plymouth fallback.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: hyperwebster-luks-tpm-status [luks-device]

Without a device, scans /etc/crypttab and common root mapper names.
Prints a checklist: TPM hardware, LUKS tokens, initramfs hooks, kernel cmdline,
and suggested fixes. Exit 0 when TPM unlock looks healthy; 1 when issues found.
EOF
}

RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
DIM='\033[2m'
NC='\033[0m'

ok()   { printf '%b[ok]%b %s\n' "$GRN" "$NC" "$*"; }
warn() { printf '%b[!!]%b %s\n' "$YLW" "$NC" "$*"; issues=$((issues + 1)); }
bad()  { printf '%b[no]%b %s\n' "$RED" "$NC" "$*"; issues=$((issues + 1)); }
note() { printf '%b    %b%s\n' "$DIM" "$NC" "$*"; }

issues=0
DEVICE="${1:-}"

tpm_present() {
  [[ -e /dev/tpmrm0 || -e /dev/tpm0 ]]
}

resolve_luks_devices() {
  local devs=()
  if [[ -n "$DEVICE" ]]; then
    devs+=("$DEVICE")
  elif [[ -f /etc/crypttab ]]; then
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ -z "${line// }" ]] && continue
      local src
      src=$(awk '{print $2}' <<<"$line")
      [[ "$src" == PARTUUID=* ]] && src="/dev/disk/by-partuuid/${src#PARTUUID=}"
      [[ "$src" == UUID=* ]] && src="/dev/disk/by-uuid/${src#UUID=}"
      [[ -n "$src" ]] && devs+=("$src")
    done < /etc/crypttab
  fi
  if [[ ${#devs[@]} -eq 0 ]] && [[ -e /dev/mapper/hyperwebster-root ]]; then
    local backing
    backing=$(cryptsetup status hyperwebster-root 2>/dev/null | awk -F: '/device/ {gsub(/^[ \t]+/,"",$2); print $2; exit}')
    [[ -n "$backing" ]] && devs+=("$backing")
  fi
  printf '%s\n' "${devs[@]}"
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

echo "HyperWebster LUKS unlock status"
echo "==============================="

# --- TPM hardware ---
if [[ -e /dev/tpmrm0 ]]; then
  ok "TPM resource manager present (/dev/tpmrm0)"
elif [[ -e /dev/tpm0 ]]; then
  ok "TPM character device present (/dev/tpm0)"
else
  bad "No TPM device — auto-unlock unavailable; passphrase fallback only"
  note "Enable TPM in firmware (PTT / fTPM) if you want silent boot later."
fi

if command -v systemd-cryptenroll >/dev/null 2>&1; then
  if tpm_list=$(systemd-cryptenroll --tpm2-device=list 2>/dev/null); then
    if [[ -n "$tpm_list" && "$tpm_list" != *"none"* ]]; then
      ok "systemd-cryptenroll sees TPM2: $(head -1 <<<"$tpm_list")"
    else
      warn "systemd-cryptenroll reports no usable TPM2 device"
    fi
  fi
else
  bad "systemd-cryptenroll missing (install systemd)"
fi

# --- Initramfs hooks ---
if [[ -f /etc/mkinitcpio.conf ]]; then
  hooks_line=$(grep -E '^HOOKS=' /etc/mkinitcpio.conf | tail -1 || true)
  if grep -qE '^HOOKS=.*\bsd-encrypt\b' /etc/mkinitcpio.conf 2>/dev/null \
     || grep -rq 'sd-encrypt' /etc/mkinitcpio.conf.d/ 2>/dev/null; then
    ok "mkinitcpio uses sd-encrypt (systemd TPM unlock in initramfs)"
  elif grep -qE '^HOOKS=.*\bencrypt\b' /etc/mkinitcpio.conf 2>/dev/null; then
    bad "mkinitcpio still uses legacy encrypt hook — migrate to sd-encrypt"
    note "Run: sudo sh ~/.local/share/hyperwebster/luks-tpm-unlock/install-luks-tpm-unlock.sh"
  else
    warn "sd-encrypt hook not found (LUKS may not be configured)"
  fi

  if grep -qE '^HOOKS=.*\bplymouth\b' /etc/mkinitcpio.conf 2>/dev/null \
     || grep -rq 'plymouth' /etc/mkinitcpio.conf.d/ 2>/dev/null; then
    if [[ -n "$hooks_line" ]] && [[ "$hooks_line" =~ sd-encrypt ]] && [[ "$hooks_line" =~ plymouth ]]; then
      plymouth_pos=$(sed -n 's/.*HOOKS=([^)]*).*/\1/p' <<<"$hooks_line" | tr ' ' '\n' | grep -n plymouth | cut -d: -f1)
      encrypt_pos=$(sed -n 's/.*HOOKS=([^)]*).*/\1/p' <<<"$hooks_line" | tr ' ' '\n' | grep -n sd-encrypt | cut -d: -f1)
      if [[ -n "$plymouth_pos" && -n "$encrypt_pos" && "$plymouth_pos" -lt "$encrypt_pos" ]]; then
        ok "Plymouth hook runs before sd-encrypt (graphical passphrase prompt)"
      else
        warn "Plymouth may run after sd-encrypt — passphrase can fall back to TTY (press Esc)"
        note "Re-run install-luks-tpm-unlock.sh or hyperwebster-update to fix hook order."
      fi
    else
      ok "Plymouth hook present in initramfs"
    fi
  else
    warn "Plymouth hook missing — LUKS prompt may use TTY instead of splash"
  fi
else
  warn "/etc/mkinitcpio.conf not found"
fi

# --- Kernel cmdline (Limine UKI or EFI entry) ---
cmdline=""
if [[ -r /proc/cmdline ]]; then
  cmdline=$(< /proc/cmdline)
fi
if [[ "$cmdline" == *rd.luks.name=* ]]; then
  ok "Kernel cmdline has rd.luks.name= (sd-encrypt mapper binding)"
  if [[ "$cmdline" != *rd.luks.options=timeout=0* && "$cmdline" != *x-systemd.device-timeout=0* ]]; then
    warn "No LUKS/device timeout=0 on cmdline — passphrase entry may time out after ~90s"
    note "Add rd.luks.options=timeout=0 and rootflags=x-systemd.device-timeout=0 via limine-update."
  fi
elif [[ "$cmdline" == *cryptdevice=* ]]; then
  warn "Legacy cryptdevice= on cmdline — migrate to rd.luks.name= for TPM tokens"
else
  note "No rd.luks.name= on running cmdline (may be unencrypted or different boot entry)"
fi

# --- crypttab ---
if [[ -f /etc/crypttab ]]; then
  if grep -qE '^[^#[:space:]].*luks' /etc/crypttab; then
    ok "/etc/crypttab lists LUKS volume(s)"
    grep -E '^[^#[:space:]]' /etc/crypttab | while read -r line; do
      note "$line"
    done
  else
    note "/etc/crypttab present but no LUKS entries"
  fi
else
  note "No /etc/crypttab (unlock may rely on kernel cmdline only)"
fi

# --- Per-volume token check ---
mapfile -t LUKS_DEVS < <(resolve_luks_devices)
if [[ ${#LUKS_DEVS[@]} -eq 0 ]]; then
  warn "Could not determine LUKS device — pass path: hyperwebster-luks-tpm-status /dev/disk/by-partuuid/…"
else
  for dev in "${LUKS_DEVS[@]}"; do
    resolved=$(readlink -f "$dev" 2>/dev/null || echo "$dev")
    echo
    echo "Volume: $resolved"
    if ! cryptsetup isLuks "$resolved" 2>/dev/null; then
      bad "$resolved is not a LUKS volume"
      continue
    fi
    if command -v systemd-cryptenroll >/dev/null 2>&1; then
      if list_out=$(systemd-cryptenroll --list "$resolved" 2>/dev/null); then
        if grep -qi tpm2 <<<"$list_out"; then
          ok "TPM2 token enrolled on $resolved"
          grep -i tpm2 <<<"$list_out" | while read -r row; do note "$row"; done
        else
          bad "No TPM2 token on $resolved — expect passphrase every boot"
          note "Fix: sudo hyperwebster-luks-tpm-enroll $resolved"
          note "If Secure Boot is off or PCRs drift, try: sudo hyperwebster-luks-tpm-enroll --pcrs 7+11 $resolved"
        fi
        if grep -qi passphrase <<<"$list_out"; then
          ok "Passphrase slot present (fallback unlock)"
        else
          warn "No passphrase slot listed — ensure you can still unlock manually"
        fi
      else
        warn "Could not list tokens on $resolved"
      fi
    fi
    if command -v tpm2_pcrread >/dev/null 2>&1 && tpm_present; then
      for pcr in 7 11; do
        if pcr_val=$(tpm2_pcrread "sha256:$pcr" 2>/dev/null | tail -1); then
          note "PCR $pcr sha256: $pcr_val"
        fi
      done
      note "PCR drift after firmware/Secure Boot changes breaks TPM unlock — re-enroll with matching --pcrs"
    fi
  done
fi

echo
if [[ $issues -eq 0 ]]; then
  echo "All checks passed — TPM unlock chain looks healthy."
  exit 0
fi
echo "$issues issue(s) found. Passphrase fallback should still work if you know the LUKS password."
echo "Run: sudo hyperwebster-luks-tpm-enroll --pcrs 7+11 <luks-device>"
exit 1
