# HDR / VRR environment for gamescope (Chimera / Deckify session)
# Sourced by session wrappers when present. Requires amdgpu + Wayland compositor
# with HDR output support (TCL T89C 4K144 VRR profile).
ENABLE_HDR_WSI=1
DXVK_HDR=1
PROTON_ENABLE_NVAPI=1
# Prefer variable refresh when the display advertises FreeSync/VRR
AMD_VULKAN_ICD=RADV
# gamescope flags are set in the session unit; these env vars steer WSI/HDR paths.
