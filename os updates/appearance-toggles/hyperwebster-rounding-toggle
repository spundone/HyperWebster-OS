#!/bin/bash
# hyperwebster-rounding-toggle — rounded vs square shell/Hyprland corners.
set -euo pipefail

HYPRVARS="${HOME}/.config/caelestia/hypr-vars.conf"
SHELLJSON="${HOME}/.config/caelestia/shell.json"
SHELLTOKENS="${HOME}/.config/caelestia/shell-tokens.json"
HYPRUSER="${HOME}/.config/caelestia/hypr-user.conf"
LAYER="${HOME}/.local/share/hyperwebster/appearance-toggles"
STATE="${HOME}/.local/state/hyperwebster/rounding-enabled"
MARK_BEGIN='# >>> hyperwebster-rounding-toggle >>>'
MARK_END='# <<< hyperwebster-rounding-toggle <<<'

usage() {
  echo "Usage: hyperwebster-rounding-toggle {enable|disable|status|toggle}" >&2
}

set_hyprvars() {
  local on="$1"
  [ -f "$HYPRVARS" ] || return 0
  if [ "$on" = 1 ]; then
    sed -i 's/^\$windowRounding = .*/$windowRounding = 8/' "$HYPRVARS"
  else
    sed -i 's/^\$windowRounding = .*/$windowRounding = 0/' "$HYPRVARS"
  fi
}

set_shelljson() {
  local on="$1"
  command -v jq >/dev/null 2>&1 || return 0
  [ -f "$SHELLJSON" ] || return 0
  local scale
  if [ "$on" = 1 ]; then scale=1; else scale=0; fi
  local tmp
  tmp=$(mktemp)
  jq --argjson scale "$scale" \
    '.appearance.rounding = (.appearance.rounding // {}) | .appearance.rounding.scale = $scale' \
    "$SHELLJSON" > "$tmp" && mv "$tmp" "$SHELLJSON"
}

set_tokens() {
  local on="$1"
  command -v jq >/dev/null 2>&1 || return 0
  [ -f "$SHELLTOKENS" ] || return 0
  local frag="$LAYER/rounding-tokens.json"
  [ -f "$frag" ] || return 0
  local tmp
  tmp=$(mktemp)
  if [ "$on" = 1 ]; then
    jq -s '.[0] * {appearance: {rounding: .[1].appearance.rounding}}' \
      "$SHELLTOKENS" "$frag" > "$tmp"
  else
    jq '.appearance.rounding = {extraSmall:0,small:0,medium:0,large:0,largeIncreased:0,extraLarge:0,extraLargeIncreased:0,extraExtraLarge:0}' \
      "$SHELLTOKENS" > "$tmp"
  fi
  mv "$tmp" "$SHELLTOKENS"
}

set_rules() {
  local on="$1"
  [ -f "$HYPRUSER" ] || return 0
  if [ "$on" = 1 ]; then
    grep -qF "$MARK_BEGIN" "$HYPRUSER" && return 0
    cat >> "$HYPRUSER" <<'EOF'

# >>> hyperwebster-rounding-toggle >>>
# Restore rounded corners on XWayland windows caelestia zeroed for flat mode.
windowrule = rounding 8, match:class steam
windowrule = rounding 8, match:class gamescope
# <<< hyperwebster-rounding-toggle <<<
EOF
  else
    sed -i "/$MARK_BEGIN/,/$MARK_END/d" "$HYPRUSER" 2>/dev/null || true
  fi
}

apply() {
  local on="$1"
  mkdir -p "$(dirname "$STATE")"
  echo "$on" > "$STATE"
  set_hyprvars "$on"
  set_shelljson "$on"
  set_tokens "$on"
  set_rules "$on"
  if command -v hyprctl >/dev/null 2>&1 && hyprctl version >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi
  if [ "$on" = 1 ]; then
    echo "Rounded corners enabled (shell tokens + Hyprland)."
  else
    echo "Square corners restored (HyperWebster flat default)."
  fi
}

case "${1:-}" in
  enable) apply 1 ;;
  disable) apply 0 ;;
  toggle)
    if [ -f "$STATE" ] && [ "$(cat "$STATE")" = 1 ]; then apply 0; else apply 1; fi
    ;;
  status)
    if [ -f "$STATE" ] && [ "$(cat "$STATE")" = 1 ]; then echo enabled; exit 0; fi
    echo disabled; exit 1
    ;;
  *) usage; exit 1 ;;
esac
